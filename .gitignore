# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
build/
.wrangler/
.vercel/

# bundled SteelCompendium data — rebuilt by CI, not committed
apps/web/public/data/
# NOTE: apps/api/src/data/monsters.json is intentionally tracked, not ignored.
# It ships as a 0-monster placeholder so the JSON import in
# apps/api/src/data/index.ts resolves on a fresh clone / in CI. `pnpm build:data`
# overwrites it locally with the full SteelCompendium ingest; that dirty-state
# diff should NOT be committed. Run
#   git update-index --skip-worktree apps/api/src/data/monsters.json
# after your first local build to suppress the diff.

# local reference clones (e.g. SteelCompendium/data-md) — used during dev, never committed
.reference/

# env
.env
.env.local
.env.*.local
.dev.vars

# editor
.vscode/
.idea/
*.swp
.DS_Store

# local agent settings (user-specific)
.claude/settings.local.json

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# test coverage
coverage/
.nyc_output/

# OS
Thumbs.db
