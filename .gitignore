.reference/

# env
.env
.env.local
.env.*.local
.dev.vars

# editor
.vscode/
.idea/
*.swp
.DS_Store

# local agent settings (user-specific)
.claude/settings.local.json

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# test coverage
coverage/
.nyc_output/

# OS
Thumbs.db
